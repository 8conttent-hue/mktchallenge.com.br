---
// Features-I: Dark Hover Reveal - Design interativo e imersivo
interface Item { icon: string; title: string; desc: string; }
interface Props { title: string; items: Item[]; }
const { title, items } = Astro.props;
---
<section class="py-24 bg-[#0a0a0a] border-t border-white/5">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-white tracking-tighter mb-4">{title}</h2>
      <div class="flex items-center gap-4">
        <div class="h-px w-24 bg-primary"></div>
        <p class="text-white/30 text-[10px] font-black uppercase tracking-[0.4em]">Toque ou passe o mouse para explorar</p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5 border border-white/5 overflow-hidden rounded-3xl">
      {items.map((item) => (
        <div class="bg-[#0f0f0f] p-10 relative overflow-hidden group min-h-[300px] flex flex-col justify-center transition-all duration-700 hover:bg-[#141414]">
          <!-- Background Accent on Hover -->
          <div class="absolute inset-0 bg-primary/5 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
          
          <div class="relative z-10 transition-all duration-500 group-hover:-translate-y-4">
            <span class="text-4xl mb-8 block grayscale group-hover:grayscale-0 transition-all duration-500 transform group-hover:scale-110">
              {item.icon}
            </span>
            <h3 class="text-xl font-bold text-white mb-4 tracking-tight group-hover:text-primary transition-colors">
              {item.title}
            </h3>
            <p class="text-sm text-white/40 leading-relaxed opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
              {item.desc}
            </p>
          </div>

          <!-- Bottom bar -->
          <div class="absolute bottom-0 left-0 h-1 w-0 bg-primary group-hover:w-full transition-all duration-700"></div>
        </div>
      ))}
    </div>
  </div>
</section>